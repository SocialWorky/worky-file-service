# APP
APP_PORT=3005
BASE_URL="http://localhost:3005"

# AUTH — must match JWT_SECRET in SocialNetwork-backend-app
JWT_SECRET="your-jwt-secret-here"

# REDIS (Bull queue)
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# INTER-SERVICE
API_BACKEND_URL="http://localhost:3000/api/v1"
NOTIFICATION_SERVICE_URL="http://localhost:3010/api/v1"
API_MESSAGES_SERVICE_URL="http://localhost:3003/api/v1"

# CORS — separate multiple origins with commas
CORS_ORIGINS="http://localhost:4200"

NODE_ENV="development"
ENVIRONMENT="dev"
APP_URL="http://localhost:3005"
NAMESPACE="social-network-dev"

# MINIO (default storage provider)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="your-minio-secret"
MINIO_BUCKET="social-network-files"
MINIO_PUBLIC_URL="http://localhost:9000"

# AWS S3 (optional — set STORAGE_PROVIDER=s3 to activate)
# STORAGE_PROVIDER=s3
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=social-network-files
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_S3_PUBLIC_URL=https://your-cdn.example.com
